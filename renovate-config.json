{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "FutureDevGuys shared Renovate preset for low-maintenance, label-driven dependency updates.",
  "extends": [
    "config:recommended",
    ":label(renovate)",
    ":semanticCommits",
    ":configMigration",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    "mergeConfidence:all-badges"
  ],
  "platformAutomerge": false,
  "rebaseWhen": "behind-base-branch",
  "dependencyDashboard": true,
  "ignorePaths": ["archived/**", "**/archived/**"],
  "prConcurrentLimit": 12,
  "prHourlyLimit": 6,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track any # renovate: annotated version pin in YAML files.",
      "managerFilePatterns": ["**/*.yml", "**/*.yaml"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(?:\\s+versioning=(?<versioning>[^\\s\\n]+))?\\n\\s*\\w+_(?:version|VERSION):\\s*(?:\\$\\{[^:}]+:-)?[\"']?(?<currentValue>[^\"'\\s\\n}]+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Atomically update the shared security workflow call and its enforced revision input.",
      "managerFilePatterns": ["/^\\.github/workflows/security-scan\\.ya?ml$/"],
      "matchStrings": [
        "    uses:\\s+FutureDevGuys/\\.github/\\.github/workflows/security-scan\\.yml@(?<currentDigest>[0-9a-f]{40})\\s*\\n    with:\\s*\\n      workflow_revision:\\s*[\"']?[0-9a-f]{40}[\"']?"
      ],
      "datasourceTemplate": "github-digest",
      "depNameTemplate": "FutureDevGuys/.github",
      "packageNameTemplate": "FutureDevGuys/.github",
      "currentValueTemplate": "security-contract-v1",
      "autoReplaceStringTemplate": "    uses: FutureDevGuys/.github/.github/workflows/security-scan.yml@{{{newDigest}}}\\n    with:\\n      workflow_revision: \"{{{newDigest}}}\""
    },
    {
      "customType": "regex",
      "description": "Atomically track the exact Renovate runtime tag/digest and its executable test oracle.",
      "managerFilePatterns": [
        "/^\\.github/workflows/renovate\\.yml$/",
        "/^\\.github/tests/test_renovate_contract\\.py$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>docker)\\s+depName=(?<depName>renovate/renovate)\\n\\s*renovate-version:\\s*[\"']?(?<currentValue>[^@\"'\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})",
        "#\\s*renovate:\\s*datasource=(?<datasource>docker)\\s+depName=(?<depName>renovate/renovate)\\nEXPECTED_RENOVATE_RUNTIME\\s*=\\s*[\"'](?<currentValue>[^@\"'\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})[\"']"
      ]
    }
  ],
  "packageRules": [
    {
      "matchFileNames": ["archived/**", "**/archived/**"],
      "enabled": false
    },
    {
      "description": "Create visible manual PRs for major updates and label them for shared automerge sweep exclusion.",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["manual-review", "major"]
    },
    {
      "description": "Label ordinary non-major updates for the identity-and-check-gated org sweep.",
      "matchUpdateTypes": ["minor", "patch", "pin", "pinDigest"],
      "automerge": false,
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict",
      "addLabels": ["automerge-candidate"]
    },
    {
      "description": "Delay single-segment Docker Hub image updates so namespace resolution can settle.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^[^.:/]+([/][^/]+)*$/"],
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "description": "Label Docker digest refreshes for the identity-and-check-gated org sweep.",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "automerge": false,
      "addLabels": ["automerge-candidate"]
    },
    {
      "description": "Label Dockerfile and Docker Compose patch/minor updates for the org sweep.",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict",
      "addLabels": ["automerge-candidate"]
    },
    {
      "description": "Label GitHub Actions routine updates for the org sweep.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest", "minor", "patch", "pin", "pinDigest"],
      "automerge": false,
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict",
      "addLabels": ["automerge-candidate"]
    },
    {
      "description": "Group GitHub Actions patch updates together when their risk class matches.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "groupName": "gha-patches",
      "automerge": false
    },
    {
      "description": "Do not apply release-age gates to immutable digest and digest-pin updates.",
      "matchUpdateTypes": ["digest", "pinDigest"],
      "minimumReleaseAge": null,
      "internalChecksFilter": "strict"
    }
  ]
}
